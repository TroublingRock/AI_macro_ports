# Copy to secrets.toml locally, or paste into Streamlit Cloud → Settings → Secrets.
# Never commit secrets.toml with real passwords/tokens.

# --- Email (optional, later) ---
EMAIL_SENDER = "your.email@gmail.com"
EMAIL_PASSWORD = "your-app-password"
SMTP_SERVER = "smtp.gmail.com"
SMTP_PORT = 587

# --- GitHub persistence (keeps tools / standards / overrides after Cloud reboot) ---
# Create a classic PAT: https://github.com/settings/tokens
#   Scopes: repo (for private) OR public_repo (public repo is enough for this project)
# Or fine-grained: Contents Read and Write on TroublingRock/AI_macro_ports
[github]
token = "ghp_your_token_here"
repo = "TroublingRock/AI_macro_ports"
branch = "main"
